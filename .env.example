# Environment Configuration Example
# Copy this file to .env.development or .env.production and configure accordingly

# Server Configuration
NODE_ENV=development
PORT=3001

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=biscas_learning
DB_USER=root
DB_PASSWORD=
DB_CONNECTION_LIMIT=10
DB_SSL=false

# JWT Configuration
# Generate a strong secret key: openssl rand -base64 32
JWT_SECRET=your-secret-key-min-256-bits
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Storage Configuration
# Options: local (development) or s3 (production)
STORAGE_TYPE=local
STORAGE_PATH=./uploads

# AWS S3 Configuration (if STORAGE_TYPE=s3)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-aws-access-key-id
# AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# AWS_S3_BUCKET=your-bucket-name

# Redis Configuration (optional, for sessions/caching)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password

# Email Configuration (for password reset)
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=your-mailtrap-user
EMAIL_PASSWORD=your-mailtrap-password
EMAIL_FROM=noreply@biscas.edu

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100


